{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "rootDir": "./",
        "outDir": "./dist",
        "moduleResolution": "node",
        "baseUrl": "./src",
        "paths": {
            "@modules/*": [
                "./modules/*"
            ],
            "@config/*": [
                "./config/*"
            ],
            "@shared/*": [
                "./shared/*"
            ],
            "@errors/*": [
                "./errors/*"
            ],
            "@utils/*": [
                "./utils/*"
            ]
        },
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true
    }
}
