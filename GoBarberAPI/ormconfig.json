        "password": "process.env.DB_PASS",
        "database": "process.env.DB_NAME",
        "entities": [
            "./src/modules/**/infra/typeorm/entities/*.ts"
        ],
        "migrations": [
            "./src/shared/infra/typeorm/migrations/*.ts"
        ],
        "cli": {
