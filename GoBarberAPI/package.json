{
    "name": "projetoode",
    "version": "1.0.0",
    "main": "index.js",
    "license": "MIT",
    "scripts": {
        "build": "tsc",
        "dev:server": "ts-node-dev -r tsconfig-paths/register --inspect --transpile-only --ignore-watch node_modules src/shared/infra/http/server.ts",
        "dev:sqlite": "cross-env NODE_ENV=development ts-node-dev -r tsconfig-paths/register --inspect --transpile-only --ignore-watch node_modules src/shared/infra/http/server.ts",
        "dev:start": "ts-node-dev -r tsconfig-paths/register --poll --inspect --transpile-only --ignore-watch node_modules --respawn src/shared/infra/http/server.ts",
        "typeorm": "ts-node-dev -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
        "migrations:run": "cross-env NODE_ENV=development ts-node-dev -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run",
        "migrations:revert": "cross-env NODE_ENV=development ts-node-dev -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert",
        "test": "jest"
    },
    "dependencies": {
        "awa": "^1.0.0",
        "aws-sdk": "^2.1121.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "date-fns": "^2.22.1",
        "express": "^4.17.2",
        "express-async-errors": "^3.1.1",
        "handlebars": "^4.7.7",
        "ioredis": "^4.30.1",
        "jsonwebtoken": "^8.5.1",
        "mime-types": "^2.1.35",
        "multer": "^1.4.2",
        "nodemailer": "^6.7.3",
        "pg": "^8.6.0",
        "reflect-metadata": "^0.1.13",
        "routes": "^2.1.0",
        "sqlite3": "^5.1.7",
        "tsyringe": "^4.6.0",
        "typeorm": "^0.2.34",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.5",
        "@types/body-parser": "^1.19.4",
        "@types/cors": "^2.8.12",
        "@types/express": "^4.17.20",
        "@types/handlebars": "^4.1.0",
        "@types/jest": "^29.5.0",
        "@types/jsonwebtoken": "^8.5.4",
        "@types/multer": "^1.4.7",
        "@types/node": "^20.8.0",
        "@types/nodemailer": "^6.4.4",
        "celebrate": "^15.0.1",
        "class-transformer": "^0.5.1",
        "cross-env": "^7.0.3",
        "jest": "^29.6.0",
        "mockdate": "^3.0.0",
        "ts-jest": "^29.1.0",
        "ts-node-dev": "^2.0.0",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.2.2"
    }
}
