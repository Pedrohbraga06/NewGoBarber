{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "rootDir": "./",
    "outDir": "./dist",
    "moduleResolution": "node",
    "baseUrl": "./src",
    "types": [
      "node",
      "express",
      "jest"
    ],
    "paths": {
      "@modules/*": [
        "./modules/*"
      ],
      "@config/*": [
        "./config/*"
      ],
      "@shared/*": [
        "./shared/*"
      ],
      "@errors/*": [
        "./errors/*"
      ],
      "@utils/*": [
        "./utils/*"
      ]
    },
  "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  }
}